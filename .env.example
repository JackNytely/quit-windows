# --- SpacetimeDB (server + browser) ---
# Maincloud (managed): https://docs.spacetimedb.com/how-to/deploy/maincloud
# The SDK accepts HTTPS; it upgrades to WebSocket as needed.
SPACETIME_URI=https://maincloud.spacetimedb.com
# Must match the database name from `apps/web/spacetime.json` and `bun run spacetime:publish` (default: quit-windows).
SPACETIME_DATABASE_NAME=quit-windows

# Public URL for the Next.js browser client (subscriptions / live stats).
NEXT_PUBLIC_SPACETIME_URI=https://maincloud.spacetimedb.com
NEXT_PUBLIC_SPACETIME_DATABASE=quit-windows

# Local dev alternative (standalone): SPACETIME_URI=http://127.0.0.1:3001 (and same for NEXT_PUBLIC_*)

# HMAC secret for hashing client IPs (use a long random string in production).
IP_HASH_SECRET=ARandomSecretStringForHashingClientIPs

# Railway (and similar hosts) set PORT automatically; Next.js uses it for `next start`.
# PORT=3000
